/*
 * EN683 VDMA — Buffer / Backing Lifecycle State Machine
 *
 * Render:
 *   dot -Tpng buf-lifecycle.dot -o buf-lifecycle.png
 *   dot -Tsvg buf-lifecycle.dot -o buf-lifecycle.svg
 *
 * backing (물리 메모리, kref'd 공유) + buf (per-session view) 두 단계 분리 모델.
 * 각 state 에서 ref 변화 표시.
 */

digraph BUF_LIFECYCLE {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, style="rounded,filled"];
    edge [fontname="Helvetica", fontsize=8];

    /* Start / End */
    start [label="●", shape=circle, fixedsize=true, width=0.4, fillcolor=black, fontcolor=white];
    end   [label="◉", shape=doublecircle, fixedsize=true, width=0.4, fillcolor=black, fontcolor=white];

    /* States */
    not_exists  [label=<<b>NotExists</b>>, fillcolor="#eceff1", shape=ellipse];

    allocated   [label=<<b>Allocated</b><br/>backing.ref=1<br/>buf.ref=1>,
                 fillcolor="#c8e6c9", shape=box];
    imported    [label=<<b>Imported</b><br/>backing.ref++<br/>buf.ref=1>,
                 fillcolor="#c8e6c9", shape=box];
    mmapped     [label=<<b>Mmapped</b><br/>buf.ref += vma>,
                 fillcolor="#a5d6a7", shape=box];
    submitted   [label=<<b>Submitted</b><br/>buf.ref += job<br/>(transient)>,
                 fillcolor="#81c784", shape=box];
    exported    [label=<<b>Exported</b><br/>backing.ref++<br/>(anon_inode fd)>,
                 fillcolor="#fff59d", shape=box];

    shared      [label=<<b>SharedAcrossProcess</b><br/>다른 process 가 IMPORT<br/>backing.ref++>,
                 fillcolor="#ffe082", shape=box];

    orphaned    [label=<<b>Orphaned</b><br/>owner=NULL<br/>다른 holder 가 유지>,
                 fillcolor="#ffccbc", shape=box];
    released    [label=<<b>Released</b><br/>backing.ref=0<br/>ecmm_free>,
                 fillcolor="#ef9a9a", shape=box];

    /* Transitions */
    start -> not_exists;

    not_exists -> allocated [label=<ALLOC ioctl>, color="#1b5e20", penwidth=1.5];
    not_exists -> imported  [label=<IMPORT ioctl>, color="#1b5e20", penwidth=1.5];

    allocated -> mmapped    [label=<mmap()<br/>buf.ref++>];
    imported  -> mmapped    [label=<mmap()<br/>buf.ref++>];

    mmapped   -> submitted  [label=<SUBMIT<br/>buf.ref++>, color="#33691e"];
    submitted -> mmapped    [label=<job done<br/>buf.ref minus 1>, color="#33691e"];

    allocated -> exported   [label=<EXPORT<br/>(mmap 전 가능)<br/>backing.ref++>, color="#f57f17"];
    mmapped   -> exported   [label=<EXPORT<br/>backing.ref++>, color="#f57f17"];

    exported  -> shared     [label=<SCM_RIGHTS + IMPORT<br/>새 buf view<br/>backing.ref++>,
                             color="#ef6c00", penwidth=2];

    mmapped   -> orphaned   [label=<FREE (user)<br/>다른 view 또는<br/>anon_fd 가 backing 잡음>,
                             color="#bf360c", style=dashed];
    shared    -> orphaned   [label=<한쪽 view 가<br/>먼저 free>,
                             color="#bf360c", style=dashed];

    mmapped   -> released   [label=<FREE 후<br/>모든 holder=0>, color="#b71c1c"];
    orphaned  -> released   [label=<마지막 view 와<br/>anon_fd 해제>, color="#b71c1c"];

    released  -> end;

    /* Notes */
    note_shared [
        label=<<b>SharedAcrossProcess</b><br/>
               • 한 backing 을 여러 view 가 공유 <br align="left"/>
               • 각 view 는 자기 session 의 bufs list 에 등록 <br align="left"/>
               • Per-session dedup : 같은 process 가 같은 backing 을 <br align="left"/>
                 두 번 import 시 기존 view 반환 (idempotent) <br align="left"/>>,
        shape=note,
        fillcolor="#fffde7",
        color="#f57f17",
        fontsize=9
    ];

    note_orphan [
        label=<<b>Orphaned</b><br/>
               • owner = NULL 상태 <br align="left"/>
               • VMA / job / anon_fd / 다른 view 중 <br align="left"/>
                 하나라도 살아있으면 backing 보존 <br align="left"/>
               • 사용자 측에선 free 성공한 것으로 보임 <br align="left"/>>,
        shape=note,
        fillcolor="#fffde7",
        color="#bf360c",
        fontsize=9
    ];

    shared   -> note_shared [style=invis];
    orphaned -> note_orphan [style=invis];

    /* Legend */
    subgraph cluster_legend {
        label=<<b>Legend</b>>;
        style="rounded,filled";
        fillcolor="#fafafa";
        color="#9e9e9e";

        L1 [label=<<b>Allocated</b>>, fillcolor="#c8e6c9", shape=box];
        L2 [label=<<b>Active</b>>, fillcolor="#fff59d", shape=box];
        L3 [label=<<b>Death</b>>, fillcolor="#ffccbc", shape=box];

        L1 -> L2 -> L3 [style=invis];
    }
}
